      "html": "<div class=\"pf-v6-c-check\"><input id=\"displaySize-checkbox\" class=\"pf-v6-c-check__input\" type=\"checkbox\" aria-invalid=\"false\" data-ouia-component-type=\"PF6/Checkbox\" data-ouia-safe=\"true\" data-ouia-component-id=\"OUIA-Generated-Checkbox-:r5n:\"><label class=\"pf-v6-c-check__label\" for=\"displaySize-checkbox\">displaySize=\"lg\"</label></div><br><div class=\"pf-v6-c-expandable-section pf-m-expanded pf-m-indented\"><div class=\"pf-v6-c-expandable-section__toggle\"><button aria-expanded=\"true\" aria-controls=\"expandable-section-content-:r5o:\" id=\"expandable-section-toggle-:r5p:\" class=\"pf-v6-c-button pf-m-link\" type=\"button\" data-ouia-component-type=\"PF6/Button\" data-ouia-safe=\"true\" data-ouia-component-id=\"OUIA-Generated-Button-link-:r5q:\"><span class=\"pf-v6-c-button__icon pf-m-start\"><span class=\"pf-v6-c-expandable-section__toggle-icon\"><svg class=\"pf-v6-svg\" fill=\"currentColor\" viewBox=\"0 0 20 20\" aria-hidden=\"true\" role=\"img\" width=\"1em\" height=\"1em\"><path d=\"M18.71 5.29a.996.996 0 0 0-1.41 0l-7.29 7.29-7.3-7.29a.987.987 0 0 0-1.41-.02.987.987 0 0 0-.02 1.41l.02.02 7.65 7.65c.29.29.68.44 1.06.44s.77-.15 1.06-.44l7.65-7.65a.996.996 0 0 0 0-1.41Z\"></path></svg></span></span><span class=\"pf-v6-c-button__text\">Show less indented example content</span></button></div><div class=\"pf-v6-c-expandable-section__content\" id=\"expandable-section-content-:r5o:\" aria-labelledby=\"expandable-section-toggle-:r5p:\" role=\"region\"> This content is visible only when the component is expanded. </div></div>"
